{
  "name": "pixel-pet-launcher",
  "version": "0.1.0",
  "description": "浅色可爱像素风桌宠启动器",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win portable"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "pixel"
  ],
  "author": "Codex",
  "license": "MIT",
  "build": {
    "appId": "com.pixelpet.launcher",
    "productName": "宠物启动器",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "pet-packages",
        "to": "pet-packages",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "宠物启动器-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  }
}
